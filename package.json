    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "ai": "^6.0.168",
    "aos": "3.0.0-beta.6",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "elasticdash-test": "0.1.24",
