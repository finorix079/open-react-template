    "start": "node -r dotenv/config ./node_modules/next/dist/bin/next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:ai": "NODE_OPTIONS='--import tsx/esm' elasticdash test",
    "dep-reset": "rm pnpm-lock.yaml && pnpm i",
    "test:elasticdash:replay": "NODE_OPTIONS='--import tsx/esm' elasticdash ed-test",
